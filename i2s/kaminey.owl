<?xml version="1.0"?>


<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY icmwindontology "http://www.icmwind.com/icmwindontology.owl#" >
]>


<rdf:RDF xmlns="http://www.semanticweb.org/kaminey.owl#"
     xml:base="http://www.semanticweb.org/kaminey.owl"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:icmwindontology="http://www.icmwind.com/icmwindontology.owl#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/kaminey.owl"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.icmwind.com/icmwindontology.owl#connectedTo -->

    <owl:ObjectProperty rdf:about="&icmwindontology;connectedTo"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#connectionFrom -->

    <owl:ObjectProperty rdf:about="&icmwindontology;connectionFrom"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#faultCondition -->

    <owl:ObjectProperty rdf:about="&icmwindontology;faultCondition"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#faultLevel -->

    <owl:ObjectProperty rdf:about="&icmwindontology;faultLevel"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#faultOccurrenceTime -->

    <owl:ObjectProperty rdf:about="&icmwindontology;faultOccurrenceTime"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#faultyComponent -->

    <owl:ObjectProperty rdf:about="&icmwindontology;faultyComponent">
        <owl:inverseOf rdf:resource="&icmwindontology;hasFault"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasConnection -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasConnection"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasFault -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasFault"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasFeatureOfInterest -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasFeatureOfInterest"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasManufacturer -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasManufacturer"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasObservation -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasObservation"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasPart -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasPart"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasPosition -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasPosition"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasProperty -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasProperty"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasSamplingTime -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasSamplingTime"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasSensor -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasSensor">
        <owl:inverseOf rdf:resource="&icmwindontology;isSensorOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasStatus -->

    <owl:ObjectProperty rdf:about="&icmwindontology;hasStatus"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#isPartOf -->

    <owl:ObjectProperty rdf:about="&icmwindontology;isPartOf">
        <owl:inverseOf rdf:resource="&icmwindontology;hasPart"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#isPropertyOf -->

    <owl:ObjectProperty rdf:about="&icmwindontology;isPropertyOf">
        <owl:inverseOf rdf:resource="&icmwindontology;hasProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#isSensorOf -->

    <owl:ObjectProperty rdf:about="&icmwindontology;isSensorOf"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#measuresParticleSize -->

    <owl:ObjectProperty rdf:about="&icmwindontology;measuresParticleSize"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#measuresProperty -->

    <owl:ObjectProperty rdf:about="&icmwindontology;measuresProperty"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#propertyMeasuredBy -->

    <owl:ObjectProperty rdf:about="&icmwindontology;propertyMeasuredBy">
        <owl:inverseOf rdf:resource="&icmwindontology;measuresProperty"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.icmwind.com/icmwindontology.owl#faultMessage -->

    <owl:DatatypeProperty rdf:about="&icmwindontology;faultMessage">
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#hasValue -->

    <owl:DatatypeProperty rdf:about="&icmwindontology;hasValue"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#isValveOpen -->

    <owl:DatatypeProperty rdf:about="&icmwindontology;isValveOpen"/>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#observedTime -->

    <owl:DatatypeProperty rdf:about="&icmwindontology;observedTime">
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.icmwind.com/icmwindontology.owl#Air -->

    <owl:Class rdf:about="&icmwindontology;Air">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Feature_Of_Interest"/>
        <owl:disjointWith rdf:resource="&icmwindontology;Oil"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Alarm -->

    <owl:Class rdf:about="&icmwindontology;Alarm">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Fault_Level"/>
        <owl:disjointWith rdf:resource="&icmwindontology;Warning"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Bigger_Than_200 -->

    <owl:Class rdf:about="&icmwindontology;Bigger_Than_200">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Size"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;hasValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="&xsd;float">200.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Bigger_Than_300 -->

    <owl:Class rdf:about="&icmwindontology;Bigger_Than_300">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Size"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;hasValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="&xsd;float">300.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Bigger_Than_500 -->

    <owl:Class rdf:about="&icmwindontology;Bigger_Than_500">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Size"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;hasValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="&xsd;float">500.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#CSM_ON -->

    <owl:Class rdf:about="&icmwindontology;CSM_ON">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Status"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;isPropertyOf"/>
                        <owl:someValuesFrom rdf:resource="&icmwindontology;Sensor"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#CS_1000 -->

    <owl:Class rdf:about="&icmwindontology;CS_1000">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Contamination_Sensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;ISO_6"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;ISO_14"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;HYDAC"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasFeatureOfInterest"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;ISO_4"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;CSM_ON"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasPosition"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Oil_Pump_To_Oil_Filter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;isSensorOf"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Gearbox"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;CS_Flow"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;CS_Drive"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#CS_Drive -->

    <owl:Class rdf:about="&icmwindontology;CS_Drive">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Drive"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;isPropertyOf"/>
                        <owl:someValuesFrom rdf:resource="&icmwindontology;Oil"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#CS_Flow -->

    <owl:Class rdf:about="&icmwindontology;CS_Flow">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Flow_Rate"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;isPropertyOf"/>
                        <owl:someValuesFrom rdf:resource="&icmwindontology;Oil"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Close -->

    <owl:Class rdf:about="&icmwindontology;Close">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Status"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;isValveOpen"/>
                <owl:someValuesFrom rdf:resource="&xsd;boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Connection -->

    <owl:Class rdf:about="&icmwindontology;Connection">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;connectionFrom"/>
                <owl:onClass rdf:resource="&icmwindontology;Sub_System"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;connectedTo"/>
                <owl:onClass rdf:resource="&icmwindontology;Sub_System"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Contamination -->

    <owl:Class rdf:about="&icmwindontology;Contamination">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Property"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Contamination_Sensor -->

    <owl:Class rdf:about="&icmwindontology;Contamination_Sensor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Sensor"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                        <owl:someValuesFrom rdf:resource="&icmwindontology;Contamination"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Cooler -->

    <owl:Class rdf:about="&icmwindontology;Cooler">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Sub_System"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;hasConnection"/>
                        <owl:onClass rdf:resource="&icmwindontology;Cooler_to_Gearbox"/>
                        <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Cooler_Temperature_Difference -->

    <owl:Class rdf:about="&icmwindontology;Cooler_Temperature_Difference">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Temperature"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Cooler_to_Gearbox -->

    <owl:Class rdf:about="&icmwindontology;Cooler_to_Gearbox">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Connection"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;connectedTo"/>
                        <owl:onClass rdf:resource="&icmwindontology;Gearbox"/>
                        <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;connectionFrom"/>
                        <owl:onClass rdf:resource="&icmwindontology;Cooler"/>
                        <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Dielectricity -->

    <owl:Class rdf:about="&icmwindontology;Dielectricity">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Property"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Differential_Pressure -->

    <owl:Class rdf:about="&icmwindontology;Differential_Pressure">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Pressure"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Differential_Pressure_Sensor -->

    <owl:Class rdf:about="&icmwindontology;Differential_Pressure_Sensor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&icmwindontology;Sensor"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                        <owl:someValuesFrom rdf:resource="&icmwindontology;Differential_Pressure"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Drive -->

    <owl:Class rdf:about="&icmwindontology;Drive">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Property"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#ETS_7000 -->

    <owl:Class rdf:about="&icmwindontology;ETS_7000">
        <rdfs:subClassOf rdf:resource="&icmwindontology;Temperature_Sensor"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#ETS_In -->

    <owl:Class rdf:about="&icmwindontology;ETS_In">
        <rdfs:subClassOf rdf:resource="&icmwindontology;ETS_7000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;T_In"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasPosition"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Cooler_to_Gearbox"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;isSensorOf"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Gearbox"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasFeatureOfInterest"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;HYDAC"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#ETS_Out -->

    <owl:Class rdf:about="&icmwindontology;ETS_Out">
        <rdfs:subClassOf rdf:resource="&icmwindontology;ETS_7000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasPosition"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Oil_Pump_To_Oil_Filter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;measuresProperty"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;T_Out"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasFeatureOfInterest"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;HYDAC"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;isSensorOf"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Gearbox"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/icmwindontology.owl#Fault -->

    <owl:Class rdf:about="&icmwindontology;Fault">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&icmwindontology;faultOccurrenceTime"/>
                <owl:someValuesFrom rdf:resource="&icmwindontology;Time"/>
