      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#Status">
    <rdfs:subClassOf rdf:resource="#Property"/>
  </owl:Class>
  <owl:Class rdf:about="#Differential_Pressure_Sensor">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
