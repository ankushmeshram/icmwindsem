        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >25</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Solid_Particle_Contamination"/>
          <owl:Restriction>
            <owl:someValuesFrom rdf:resource="#Smaller_Than_14"/>
            <owl:onProperty rdf:resource="#measuresParticleSize"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#Fluids">
    <rdfs:subClassOf rdf:resource="#Feature_Of_Interest"/>
    <owl:disjointWith rdf:resource="#Air"/>
  </owl:Class>
  <owl:Class rdf:ID="TOSS_Temperature_Sensor">
    <rdfs:subClassOf rdf:resource="#Temperature_Sensor"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#Cooler"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#hasPosition"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#T_Air"/>
        <owl:onProperty rdf:resource="#observes"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#TOSS"/>
        <owl:onProperty rdf:resource="#hasManufacturer"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#Air"/>
        <owl:onProperty rdf:resource="#hasFeatureOfInterest"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#Ferromagnetic_Particles_Contamination">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Metallic_Particle_Contamination"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#Water_Solvency">
    <rdfs:subClassOf rdf:resource="#Property"/>
  </owl:Class>
  <owl:Class rdf:about="#Sensor">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#Manufacturer"/>
        <owl:onProperty rdf:resource="#hasManufacturer"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="#hasPosition"/>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf rdf:parseType="Collection">
              <owl:Class rdf:about="#Connection"/>
              <owl:Class rdf:about="#Component"/>
            </owl:unionOf>
          </owl:Class>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#Property"/>
        <owl:onProperty rdf:resource="#observes"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#Feature_Of_Interest"/>
        <owl:onProperty rdf:resource="#hasFeatureOfInterest"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#High_Cooler_Temperature_Difference">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Cooler_Temperature_Difference"/>
          <owl:Restriction>
            <owl:onProperty rdf:resource="#hasValue"/>
            <owl:someValuesFrom>
              <rdfs:Datatype>
                <owl:withRestrictions rdf:parseType="Collection">
                  <rdf:Description>
                    <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
                    >10.0</xsd:minExclusive>
                  </rdf:Description>
                </owl:withRestrictions>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
              </rdfs:Datatype>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#Cooler">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Component"/>
          <owl:Restriction>
            <owl:onClass rdf:resource="#Cooler_to_Gearbox"/>
            <owl:onProperty rdf:resource="#hasConnection"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
