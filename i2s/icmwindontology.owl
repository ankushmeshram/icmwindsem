            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#MCS_F">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >30000</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Non_Ferromagnetic_Particles_Contamination"/>
          <owl:Restriction>
            <owl:someValuesFrom rdf:resource="#Bigger_Than_500"/>
            <owl:onProperty rdf:resource="#measuresParticleSize"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#Metallic_Particle_Contamination">
    <rdfs:subClassOf rdf:resource="#Contamination"/>
  </owl:Class>
  <owl:Class rdf:about="#Bigger_Than_200">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Size"/>
          <owl:Restriction>
            <owl:onProperty rdf:resource="#hasValue"/>
            <owl:someValuesFrom>
              <rdfs:Datatype>
                <owl:withRestrictions rdf:parseType="Collection">
                  <rdf:Description>
                    <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
                    >200.0</xsd:maxExclusive>
                  </rdf:Description>
                </owl:withRestrictions>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
              </rdfs:Datatype>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#Differential_Pressure">
    <rdfs:subClassOf rdf:resource="#Pressure"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="#faultySensor">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="hasFault"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#observedBy">
    <owl:inverseOf rdf:resource="#observes"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#faultyComponent">
    <owl:inverseOf rdf:resource="#hasFault"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isPartOf">
    <owl:inverseOf rdf:resource="#hasPart"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#hasStatus">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >has status</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isPropertyOf">
    <owl:inverseOf rdf:resource="#hasProperty"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="#observedTime">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="#faultMessage">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:AllDisjointClasses>
    <owl:members rdf:parseType="Collection">
      <owl:Class rdf:about="#Cooler_to_Gearbox"/>
      <owl:Class rdf:about="#Gearbox_To_Oil_Pump"/>
      <owl:Class rdf:about="#Oil_Filter_To_Thermo_Bypass_Valve"/>
      <owl:Class rdf:about="#Oil_Pump_To_Oil_Filter"/>
      <owl:Class rdf:about="#Thermo_Bypass_Valve_To_Cooler"/>
      <owl:Class rdf:about="#Thermo_Bypass_Valve_To_Gearbox"/>
    </owl:members>
  </owl:AllDisjointClasses>
  <owl:AllDisjointClasses>
    <owl:members rdf:parseType="Collection">
      <owl:Class rdf:about="#Cooler"/>
      <owl:Class rdf:about="#Gearbox"/>
      <owl:Class rdf:about="#Oil_Filter"/>
      <owl:Class rdf:about="#Oil_Pump"/>
      <owl:Class rdf:about="#Thermo_Bypass_Valve"/>
    </owl:members>
  </owl:AllDisjointClasses>
  <spl:Argument rdf:nodeID="A0">
    <spl:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Minimum value measured</rdfs:comment>
    <spl:predicate rdf:resource="http://spinrdf.org/sp#arg1"/>
  </spl:Argument>
  <rdf:Description rdf:nodeID="A1">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:parseType="Resource">
      <sp:object rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
      >Replace the sensor</sp:object>
      <sp:predicate rdf:resource="#faultMessage"/>
      <sp:subject rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >alm</sp:varName>
      </sp:subject>
    </rdf:first>
  </rdf:Description>
  <createTimeStamp rdf:nodeID="A2">
    <sp:arg2 rdf:resource="http://spinrdf.org/spin#_this"/>
    <sp:arg1>SF</sp:arg1>
  </createTimeStamp>
  <rdf:Description rdf:nodeID="A3">
    <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >outtemp</sp:varName>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A4">
    <rdf:first rdf:parseType="Resource">
      <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
      >value</sp:varName>
    </rdf:first>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A5">
    <sp:object rdf:resource="#Alarm"/>
    <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
    <sp:subject rdf:parseType="Resource">
      <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
      >alm</sp:varName>
    </sp:subject>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A6">
    <rdf:rest rdf:parseType="Collection">
      <rdf:Description>
        <sp:object rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >obs</sp:varName>
        </sp:object>
        <sp:predicate rdf:resource="#hasObservation"/>
        <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
      </rdf:Description>
      <rdf:Description>
        <sp:object rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >time</sp:varName>
        </sp:object>
        <sp:predicate rdf:resource="#hasSamplingTime"/>
        <sp:subject rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >obs</sp:varName>
        </sp:subject>
      </rdf:Description>
    </rdf:rest>
    <rdf:first>
      <sp:Bind>
        <sp:expression>
          <sp:iri>
            <sp:arg1>
              <createTimeStamp>
                <sp:arg2 rdf:resource="http://spinrdf.org/spin#_this"/>
                <sp:arg1>ALM</sp:arg1>
              </createTimeStamp>
            </sp:arg1>
          </sp:iri>
        </sp:expression>
        <sp:variable rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >alm</sp:varName>
        </sp:variable>
      </sp:Bind>
    </rdf:first>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A7">
    <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >t2</sp:varName>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A8">
    <rdf:rest rdf:nodeID="A1"/>
    <rdf:first rdf:nodeID="A5"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A9">
