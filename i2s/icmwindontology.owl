        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#Sensor"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="CS_Flow">
    <spin:rule>
