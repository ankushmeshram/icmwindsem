    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="installedAt"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#Component"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="monitoredProperty"/>
        </owl:onProperty>
        <owl:someValuesFrom rdf:resource="#Property"/>
