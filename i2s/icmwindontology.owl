        <owl:onProperty rdf:resource="#hasManufacturer"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#Speed"/>
        <owl:onProperty rdf:resource="#observes"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom rdf:resource="#Gearbox"/>
        <owl:onProperty rdf:resource="#hasPosition"/>
