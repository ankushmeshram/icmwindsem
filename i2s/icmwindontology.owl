      >t2</sp:varName>
    </sp:object>
    <sp:predicate rdf:resource="#hasValue"/>
    <sp:subject rdf:parseType="Resource">
      <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
      >outtemp</sp:varName>
    </sp:subject>
  </rdf:Description>
  <sp:concat rdf:nodeID="A14">
    <sp:arg2>_</sp:arg2>
    <sp:arg1 rdf:resource="http://spinrdf.org/spin#_arg1"/>
  </sp:concat>
  <rdf:Description rdf:nodeID="A15">
    <rdf:rest rdf:parseType="Resource">
      <rdf:rest rdf:nodeID="A6"/>
      <rdf:first>
        <sp:Bind>
          <sp:expression>
            <sp:iri>
              <sp:arg1 rdf:nodeID="A2"/>
            </sp:iri>
          </sp:expression>
          <sp:variable rdf:parseType="Resource">
            <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
            >flt</sp:varName>
          </sp:variable>
        </sp:Bind>
      </rdf:first>
    </rdf:rest>
    <rdf:first rdf:parseType="Resource">
      <sp:object rdf:resource="http://spinrdf.org/spin#_this"/>
      <sp:predicate rdf:resource="#observes"/>
      <sp:subject rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >sensor</sp:varName>
      </sp:subject>
    </rdf:first>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A16">
    <rdf:rest rdf:nodeID="A12"/>
    <rdf:first rdf:parseType="Resource">
      <sp:object rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >time</sp:varName>
      </sp:object>
      <sp:predicate rdf:resource="#faultOccurrenceTime"/>
      <sp:subject rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >flt</sp:varName>
      </sp:subject>
    </rdf:first>
  </rdf:Description>
  <sp:sub rdf:nodeID="A17">
    <sp:arg2 rdf:nodeID="A7"/>
    <sp:arg1 rdf:nodeID="A11"/>
  </sp:sub>
  <rdf:Description rdf:nodeID="A18">
    <rdf:rest rdf:parseType="Collection">
      <rdf:Description>
        <sp:object rdf:resource="#HLB_Temp"/>
        <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
        <sp:subject rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >intemp</sp:varName>
        </sp:subject>
      </rdf:Description>
      <rdf:Description>
        <sp:object rdf:resource="http://spinrdf.org/spin#_arg1"/>
        <sp:predicate rdf:resource="#hasObservation"/>
        <sp:subject rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >intemp</sp:varName>
        </sp:subject>
      </rdf:Description>
      <rdf:Description>
        <sp:object rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >t1</sp:varName>
        </sp:object>
        <sp:predicate rdf:resource="#hasValue"/>
        <sp:subject rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >intemp</sp:varName>
        </sp:subject>
      </rdf:Description>
      <sp:Bind>
        <sp:expression>
          <sp:abs>
            <sp:arg1 rdf:nodeID="A17"/>
          </sp:abs>
        </sp:expression>
        <sp:variable rdf:parseType="Resource">
          <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
          >value</sp:varName>
