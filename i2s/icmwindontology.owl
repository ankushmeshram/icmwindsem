    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#Drive">
    <rdfs:subClassOf rdf:resource="#Property"/>
  </owl:Class>
  <owl:Class rdf:ID="Cooler_Temperature_Difference">
    <spin:rule>
      <sp:Construct>
        <sp:templates rdf:parseType="Collection">
          <rdf:Description>
            <sp:object>
              <owl:Class rdf:ID="High_Cooler_Temperature_Difference"/>
            </sp:object>
            <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >ans</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >ans</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >ans</sp:varName>
            </sp:subject>
          </rdf:Description>
        </sp:templates>
        <sp:where rdf:parseType="Collection">
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
          <sp:Filter>
            <sp:expression>
              <sp:gt>
                <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
                >10</sp:arg2>
                <sp:arg1 rdf:parseType="Resource">
                  <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
                  >value</sp:varName>
                </sp:arg1>
              </sp:gt>
            </sp:expression>
          </sp:Filter>
          <sp:Bind>
            <sp:expression>
              <sp:iri>
                <sp:arg1>
                  <createTimeStamp>
                    <sp:arg2 rdf:resource="http://spinrdf.org/spin#_this"/>
                    <sp:arg1>HCTD</sp:arg1>
                  </createTimeStamp>
                </sp:arg1>
              </sp:iri>
            </sp:expression>
            <sp:variable rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >ans</sp:varName>
            </sp:variable>
          </sp:Bind>
        </sp:where>
      </sp:Construct>
    </spin:rule>
    <spin:rule>
      <sp:Construct>
        <sp:templates rdf:parseType="Collection">
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >diff</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
        </sp:templates>
        <sp:where rdf:parseType="Collection">
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
          <sp:Bind>
            <sp:expression>
              <coolerTemperatureDifference>
                <sp:arg1 rdf:parseType="Resource">
                  <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
                  >obs</sp:varName>
                </sp:arg1>
              </coolerTemperatureDifference>
            </sp:expression>
            <sp:variable rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >diff</sp:varName>
            </sp:variable>
          </sp:Bind>
        </sp:where>
      </sp:Construct>
    </spin:rule>
    <rdfs:subClassOf rdf:resource="#Temperature"/>
  </owl:Class>
  <owl:Class rdf:about="#Thermo_Bypass_Valve_To_Gearbox">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Connection"/>
          <owl:Restriction>
            <owl:onClass rdf:resource="#Gearbox"/>
            <owl:onProperty rdf:resource="#connectedTo"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
          <owl:Restriction>
            <owl:onProperty rdf:resource="#connectionFrom"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
            <owl:onClass rdf:resource="#Thermo_Bypass_Valve"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
