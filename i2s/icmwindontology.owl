  <sp:Bind rdf:nodeID="A27">
    <sp:expression>
      <sp:concat>
        <sp:arg2>
          <sp:concat>
            <sp:arg2 rdf:nodeID="A19"/>
            <sp:arg1 rdf:nodeID="A14"/>
          </sp:concat>
        </sp:arg2>
        <sp:arg1>http://www.icmwind.com/icmwindontology.owl#</sp:arg1>
      </sp:concat>
    </sp:expression>
