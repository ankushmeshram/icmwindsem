  <owl:Class rdf:about="#Speed_Sensor">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Sensor"/>
          <owl:Restriction>
            <owl:someValuesFrom rdf:resource="#Speed"/>
            <owl:onProperty rdf:resource="#observes"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#VLGW_dP">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >10</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <spin:rule>
      <sp:Construct>
        <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >High Pressure Difference with value &gt; 3 , according to Expert's Knowledge</rdfs:comment>
        <sp:templates rdf:parseType="Collection">
          <rdf:Description>
            <sp:object rdf:resource="#High_Differential_Pressure"/>
            <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >hdp</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >hdp</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >hdp</sp:varName>
            </sp:subject>
          </rdf:Description>
        </sp:templates>
        <sp:where rdf:parseType="Collection">
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
          <sp:Filter>
            <sp:expression>
              <sp:gt>
                <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
                >3</sp:arg2>
                <sp:arg1 rdf:parseType="Resource">
                  <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
                  >value</sp:varName>
                </sp:arg1>
              </sp:gt>
            </sp:expression>
          </sp:Filter>
          <sp:Bind>
            <sp:expression>
              <sp:iri>
                <sp:arg1>
                  <createTimeStamp>
                    <sp:arg2 rdf:resource="http://spinrdf.org/spin#_this"/>
                    <sp:arg1>HDP</sp:arg1>
                  </createTimeStamp>
                </sp:arg1>
              </sp:iri>
            </sp:expression>
            <sp:variable rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >hdp</sp:varName>
            </sp:variable>
          </sp:Bind>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
        </sp:where>
      </sp:Construct>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Differential_Pressure"/>
          <owl:Restriction>
            <owl:someValuesFrom rdf:resource="#Oil"/>
            <owl:onProperty>
              <owl:ObjectProperty rdf:about="#isPropertyOf"/>
            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="Fluid_Condition_Monitoring">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="consistsOf"/>
        </owl:onProperty>
