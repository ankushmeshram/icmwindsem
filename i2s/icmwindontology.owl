      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#P_Saug">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >-1</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >9</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Pressure"/>
          <owl:Restriction>
            <owl:someValuesFrom rdf:resource="#Oil"/>
            <owl:onProperty>
              <owl:ObjectProperty rdf:about="#isPropertyOf"/>
            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
