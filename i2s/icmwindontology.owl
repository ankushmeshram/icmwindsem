        >flt</sp:varName>
      </sp:subject>
    </rdf:first>
  </rdf:Description>
  <rdf:Description rdf:nodeID="A21">
    <rdf:rest rdf:nodeID="A20"/>
    <rdf:first rdf:parseType="Resource">
      <sp:object rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >sensor</sp:varName>
      </sp:object>
      <sp:predicate rdf:resource="#faultySensor"/>
      <sp:subject rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >flt</sp:varName>
      </sp:subject>
    </rdf:first>
  </rdf:Description>
  <spl:Argument rdf:nodeID="A22">
    <spl:valueType rdf:resource="#Observation"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Observation at which the cooler temperature difference will be measured</rdfs:comment>
    <spl:predicate rdf:resource="http://spinrdf.org/sp#arg1"/>
  </spl:Argument>
  <sp:Filter rdf:nodeID="A23">
    <sp:expression>
      <sp:or>
        <sp:arg2>
          <sp:gt>
            <sp:arg2 rdf:resource="http://spinrdf.org/spin#_arg2"/>
            <sp:arg1 rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:arg1>
          </sp:gt>
        </sp:arg2>
        <sp:arg1>
          <sp:lt>
            <sp:arg2 rdf:resource="http://spinrdf.org/spin#_arg1"/>
            <sp:arg1 rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:arg1>
          </sp:lt>
        </sp:arg1>
      </sp:or>
    </sp:expression>
  </sp:Filter>
  <rdf:Description rdf:nodeID="A24">
    <rdf:rest rdf:nodeID="A21"/>
    <rdf:first rdf:parseType="Resource">
      <sp:object rdf:resource="#Sensor_Fault"/>
      <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
      <sp:subject rdf:parseType="Resource">
        <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >flt</sp:varName>
      </sp:subject>
    </rdf:first>
  </rdf:Description>
  <sp:str rdf:nodeID="A25">
    <sp:arg1 rdf:resource="http://spinrdf.org/spin#_arg2"/>
  </sp:str>
  <spl:Argument rdf:nodeID="A26">
    <spl:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Maximum value measured</rdfs:comment>
    <spl:predicate rdf:resource="http://spinrdf.org/sp#arg2"/>
