<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns="http://www.icmwind.com/icmwindontology.owl#"
    xmlns:spin="http://spinrdf.org/spin#"
    xmlns:sp="http://spinrdf.org/sp#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:spl="http://spinrdf.org/spl#"
  xml:base="http://www.icmwind.com/icmwindontology.owl">
  <owl:Ontology rdf:about="">
    <owl:imports rdf:resource="http://spinrdf.org/spin"/>
  </owl:Ontology>
  <owl:Class rdf:ID="MCS_C">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >30000</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Ferromagnetic_Particles_Contamination"/>
          <owl:Restriction>
            <owl:someValuesFrom>
              <owl:Class rdf:ID="Bigger_Than_500"/>
            </owl:someValuesFrom>
            <owl:onProperty>
              <owl:ObjectProperty rdf:ID="measuresParticleSize"/>
            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="HYDAC_Lab">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="Sensor"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="HLB_DK"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="observes"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="HLB_S"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#observes"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="HYDAC"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="hasManufacturer"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="Thermo_Bypass_Valve_To_Cooler"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="hasPosition"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="Oil"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="hasFeatureOfInterest"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="HLB_Temp"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#observes"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Gearbox_To_Oil_Pump">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Connection"/>
          <owl:Restriction>
            <owl:onClass>
              <owl:Class rdf:ID="Oil_Pump"/>
            </owl:onClass>
            <owl:onProperty>
              <owl:ObjectProperty rdf:ID="connectedTo"/>
            </owl:onProperty>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
          <owl:Restriction>
            <owl:onClass>
              <owl:Class rdf:ID="Gearbox"/>
            </owl:onClass>
            <owl:onProperty>
              <owl:ObjectProperty rdf:ID="connectionFrom"/>
            </owl:onProperty>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="Close">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Status"/>
          <owl:Restriction>
            <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean"
            >false</owl:hasValue>
            <owl:onProperty>
              <owl:DatatypeProperty rdf:ID="isValveOpen"/>
            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Status"/>
    </rdfs:subClassOf>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Closed</rdfs:label>
  </owl:Class>
  <owl:Class rdf:ID="Warning">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="Fault_Level"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="ISO_6">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >25</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Solid_Particle_Contamination"/>
          <owl:Restriction>
            <owl:someValuesFrom>
              <owl:Class rdf:ID="Smaller_Than_6"/>
            </owl:someValuesFrom>
            <owl:onProperty rdf:resource="#measuresParticleSize"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="Oil_Filter_To_Thermo_Bypass_Valve">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Connection"/>
          <owl:Restriction>
            <owl:onProperty rdf:resource="#connectedTo"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
            <owl:onClass>
              <owl:Class rdf:ID="Thermo_Bypass_Valve"/>
            </owl:onClass>
          </owl:Restriction>
          <owl:Restriction>
            <owl:onClass>
              <owl:Class rdf:ID="Oil_Filter"/>
            </owl:onClass>
            <owl:onProperty rdf:resource="#connectionFrom"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="Temperature">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="Property"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="ETS_Out">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="ETS_7000"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="Oil_Pump_To_Oil_Filter"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#hasPosition"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#Oil"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#hasFeatureOfInterest"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#HYDAC"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#hasManufacturer"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="T_Out"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#observes"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Fault">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="Time"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="faultOccurrenceTime"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#Fault_Level"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="faultLevel"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="MCS_D">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >30000</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Non_Ferromagnetic_Particles_Contamination"/>
          <owl:Restriction>
            <owl:someValuesFrom>
              <owl:Class rdf:ID="Bigger_Than_200"/>
            </owl:someValuesFrom>
            <owl:onProperty rdf:resource="#measuresParticleSize"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#Gearbox">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:ID="Component"/>
          <owl:Restriction>
            <owl:onClass rdf:resource="#Gearbox_To_Oil_Pump"/>
            <owl:onProperty>
              <owl:ObjectProperty rdf:ID="hasConnection"/>
            </owl:onProperty>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="Unit_Of_Measurement"/>
  <owl:Class rdf:ID="Contamination">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Property"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#Oil_Filter">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Component"/>
          <owl:Restriction>
            <owl:onClass rdf:resource="#Oil_Filter_To_Thermo_Bypass_Valve"/>
            <owl:onProperty rdf:resource="#hasConnection"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:ID="CSM_ON">
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >100</sp:arg2>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Status"/>
          <owl:Restriction>
            <owl:onProperty>
              <owl:ObjectProperty rdf:ID="isPropertyOf"/>
            </owl:onProperty>
            <owl:someValuesFrom>
              <owl:Class rdf:about="#Sensor"/>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:Class rdf:about="#Component">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="hasSensor"/>
        </owl:onProperty>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#Sensor"/>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="Manufacturer"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#hasManufacturer"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:ID="System"/>
        </owl:someValuesFrom>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="isPartOf"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:someValuesFrom>
          <owl:Class rdf:about="#Connection"/>
        </owl:someValuesFrom>
        <owl:onProperty rdf:resource="#hasConnection"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="#HLB_Temp">
    <spin:rule>
      <sp:Construct>
        <sp:templates rdf:parseType="Collection">
          <rdf:Description>
            <sp:object>
              <owl:Class rdf:ID="Open"/>
            </sp:object>
            <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean"
            >true</sp:object>
            <sp:predicate rdf:resource="#isValveOpen"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:object>
            <sp:predicate>
              <owl:ObjectProperty rdf:ID="hasStatus"/>
            </sp:predicate>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >valve</sp:varName>
            </sp:subject>
          </rdf:Description>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate>
              <owl:ObjectProperty rdf:ID="hasObservation"/>
            </sp:predicate>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >valve</sp:varName>
            </sp:subject>
          </rdf:Description>
        </sp:templates>
        <sp:where rdf:parseType="Collection">
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
            <sp:predicate>
              <owl:DatatypeProperty rdf:ID="hasValue"/>
            </sp:predicate>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
          <sp:Filter>
            <sp:expression>
              <sp:lt>
                <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
                >55</sp:arg2>
                <sp:arg1 rdf:parseType="Resource">
                  <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
                  >value</sp:varName>
                </sp:arg1>
              </sp:lt>
            </sp:expression>
          </sp:Filter>
          <rdf:Description>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:Description>
          <rdf:Description>
            <sp:object>
              <owl:Class rdf:about="#Thermo_Bypass_Valve"/>
            </sp:object>
            <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >valve</sp:varName>
            </sp:subject>
          </rdf:Description>
          <sp:Bind>
            <sp:expression>
              <sp:iri>
                <sp:arg1>
                  <createTimeStamp>
                    <sp:arg2 rdf:resource="http://spinrdf.org/spin#_this"/>
                    <sp:arg1>Open</sp:arg1>
                  </createTimeStamp>
                </sp:arg1>
              </sp:iri>
            </sp:expression>
            <sp:variable rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:variable>
          </sp:Bind>
        </sp:where>
      </sp:Construct>
    </spin:rule>
    <spin:rule>
      <CreateValueRangeFault>
        <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >80</sp:arg2>
        <sp:arg1 rdf:datatype="http://www.w3.org/2001/XMLSchema#float"
        >0</sp:arg1>
      </CreateValueRangeFault>
    </spin:rule>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Temperature"/>
          <owl:Restriction>
            <owl:someValuesFrom>
              <owl:Class rdf:about="#Oil"/>
            </owl:someValuesFrom>
            <owl:onProperty>
              <owl:ObjectProperty rdf:about="#isPropertyOf"/>
            </owl:onProperty>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
    <spin:rule>
      <sp:Construct>
        <sp:where rdf:parseType="Collection">
          <rdf:Description>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
          </rdf:Description>
          <sp:Filter>
            <sp:expression>
              <sp:gt>
                <sp:arg1 rdf:parseType="Resource">
                  <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
                  >value</sp:varName>
                </sp:arg1>
                <sp:arg2 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
                >55</sp:arg2>
              </sp:gt>
            </sp:expression>
          </sp:Filter>
          <rdf:Description>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
          </rdf:Description>
          <rdf:Description>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >valve</sp:varName>
            </sp:subject>
            <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
            <sp:object>
              <owl:Class rdf:about="#Thermo_Bypass_Valve"/>
            </sp:object>
          </rdf:Description>
          <sp:Bind>
            <sp:variable rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:variable>
            <sp:expression>
              <sp:iri>
                <sp:arg1>
                  <createTimeStamp>
                    <sp:arg1>Close</sp:arg1>
                    <sp:arg2 rdf:resource="http://spinrdf.org/spin#_this"/>
                  </createTimeStamp>
                </sp:arg1>
              </sp:iri>
            </sp:expression>
          </sp:Bind>
        </sp:where>
        <sp:templates rdf:parseType="Collection">
          <rdf:Description>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:subject>
            <sp:predicate rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
            <sp:object rdf:resource="#Close"/>
          </rdf:Description>
          <rdf:Description>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:subject>
            <sp:predicate rdf:resource="#isValveOpen"/>
            <sp:object rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean"
            >false</sp:object>
          </rdf:Description>
          <rdf:Description>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:subject>
            <sp:predicate rdf:resource="#hasObservation"/>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >obs</sp:varName>
            </sp:object>
          </rdf:Description>
          <rdf:Description>
            <sp:subject rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >valve</sp:varName>
            </sp:subject>
            <sp:predicate>
              <owl:ObjectProperty rdf:about="#hasStatus"/>
            </sp:predicate>
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >sts</sp:varName>
            </sp:object>
          </rdf:Description>
          <rdf:Description>
            <sp:subject rdf:parseType="Resource">
