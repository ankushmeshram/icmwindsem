    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Initial prefix as string used to define what kind of instance is it</rdfs:comment>
    <spl:predicate rdf:resource="http://spinrdf.org/sp#arg1"/>
  </spl:Argument>
  <rdf:Description rdf:nodeID="A29">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="A27"/>
  </rdf:Description>
  <spl:Argument rdf:nodeID="A30">
    <spl:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >URI which will be used to create time stamp</rdfs:comment>
    <spl:predicate rdf:resource="http://spinrdf.org/sp#arg2"/>
  </spl:Argument>
  <spin:ConstructTemplate rdf:ID="CreateValueRangeFault">
    <spin:body>
      <sp:Construct>
        <sp:templates rdf:nodeID="A24"/>
        <sp:where rdf:parseType="Resource">
          <rdf:rest rdf:parseType="Resource">
            <rdf:rest rdf:nodeID="A15"/>
            <rdf:first rdf:nodeID="A23"/>
          </rdf:rest>
          <rdf:first rdf:parseType="Resource">
            <sp:object rdf:parseType="Resource">
              <sp:varName rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
              >value</sp:varName>
            </sp:object>
            <sp:predicate rdf:resource="#hasValue"/>
            <sp:subject rdf:resource="http://spinrdf.org/spin#_this"/>
          </rdf:first>
        </sp:where>
      </sp:Construct>
    </spin:body>
    <rdfs:subClassOf rdf:resource="http://spinrdf.org/spin#ConstructTemplates"/>
    <spin:constraint rdf:nodeID="A26"/>
    <spin:constraint rdf:nodeID="A0"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Create value range fault</rdfs:label>
    <spin:labelTemplate rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Check Value Range fault for ?this Property with range ( {?arg1}, {?arg2}) .</spin:labelTemplate>
  </spin:ConstructTemplate>
  <rdf:Description rdf:nodeID="A31">
    <rdf:rest rdf:nodeID="A29"/>
    <rdf:first>
      <sp:Bind>
        <sp:expression>
          <sp:strafter>
            <sp:arg2>#</sp:arg2>
            <sp:arg1 rdf:nodeID="A25"/>
          </sp:strafter>
        </sp:expression>
        <sp:variable rdf:parseType="Resource">
