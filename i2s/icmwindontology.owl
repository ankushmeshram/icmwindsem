          >part</sp:varName>
        </sp:variable>
      </sp:Bind>
    </rdf:first>
  </rdf:Description>
  <spin:Function rdf:ID="createTimeStamp">
    <spin:body>
      <sp:Select>
        <sp:resultVariables rdf:nodeID="A10"/>
        <sp:where rdf:nodeID="A31"/>
      </sp:Select>
    </spin:body>
    <spin:returnType rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <spin:constraint rdf:nodeID="A30"/>
    <spin:constraint rdf:nodeID="A28"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >create time stamp</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://spinrdf.org/spin#Functions"/>
  </spin:Function>
  <sp:Select rdf:nodeID="A32">
    <sp:resultVariables rdf:nodeID="A4"/>
    <sp:where rdf:parseType="Resource">
      <rdf:rest rdf:parseType="Resource">
        <rdf:rest rdf:nodeID="A18"/>
        <rdf:first rdf:nodeID="A9"/>
