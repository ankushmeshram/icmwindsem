            >1</owl:qualifiedCardinality>
            <owl:onClass>
              <owl:Class rdf:about="#Cooler"/>
            </owl:onClass>
          </owl:Restriction>
          <owl:Restriction>
            <owl:onProperty rdf:resource="#connectionFrom"/>
            <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
            >1</owl:qualifiedCardinality>
            <owl:onClass rdf:resource="#Thermo_Bypass_Valve"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
