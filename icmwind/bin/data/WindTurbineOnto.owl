<?xml version="1.0"?>


<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
]>


<rdf:RDF xmlns="http://www.icmwind.com/WindTurbineOnto.owl#"
     xml:base="http://www.icmwind.com/WindTurbineOnto.owl"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
    <owl:Ontology rdf:about="http://www.icmwind.com/WindTurbineOnto.owl">
        <rdfs:comment>This ontology represents Wind Turbine and associates various concepts of the doman through relations or roles.</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#attachedSystem -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#attachedSystem"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#deployedOnPlatform -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#deployedOnPlatform">
        <owl:inverseOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#attachedSystem"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#faultLevel -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#faultLevel"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#faultOccurrenceTime -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#faultOccurrenceTime"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#faultyComponent -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#faultyComponent">
        <owl:inverseOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasFault"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#faultyMeasuredProperty -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#faultyMeasuredProperty"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasConnection -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasConnection"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasConnectionFrom -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasConnectionFrom"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasFault -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasFault">
        <rdfs:subPropertyOf rdf:resource="&owl;topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasFeatureOfInterest -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasFeatureOfInterest"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasLocalLocation -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasLocalLocation">
        <rdfs:subPropertyOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasLocation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasLocation -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasLocation"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasManufacturer -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasManufacturer"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasObservation -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasObservation"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingProperty -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingProperty"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingRange -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingRange"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasPart -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasPart"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasPhysicalLocation -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasPhysicalLocation">
        <rdfs:subPropertyOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasLocation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasProperty -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasProperty">
        <owl:inverseOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasSamplingTime -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasSamplingTime"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasSensor -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasSensor"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasSurvivalProperty -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasSurvivalProperty"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasSurvivalRange -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasSurvivalRange"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasUnitOfMeasurement -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasUnitOfMeasurement"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#implements -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#implements"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#isConnectedTo -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#isConnectedTo">
        <rdfs:subPropertyOf rdf:resource="&owl;topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#isPartOf -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#isPartOf">
        <owl:inverseOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasPart"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#isSensorOf -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#isSensorOf">
        <owl:inverseOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasSensor"/>
    </owl:ObjectProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#measuredParticleSize -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#measuredParticleSize"/>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty -->

    <owl:ObjectProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#faultMessage -->

    <owl:DatatypeProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#faultMessage">
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#hasValue -->

    <owl:DatatypeProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#hasValue">
        <rdfs:range rdf:resource="&xsd;float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#observedTime -->

    <owl:DatatypeProperty rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#observedTime">
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Air -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Air">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#FeatureOfInterest"/>
        <owl:disjointWith rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Alarm -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Alarm">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Fault_Level"/>
        <owl:disjointWith rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Warning"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Bar -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Bar">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#UnitOfMeasurement"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#BiggerThan200um -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#BiggerThan200um">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#ParticleSize"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="&xsd;float"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minExclusive rdf:datatype="&xsd;float">200.0</xsd:minExclusive>
                            </rdf:Description>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#BiggerThan300um -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#BiggerThan300um">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#ParticleSize"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="&xsd;float"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minExclusive rdf:datatype="&xsd;float">300.0</xsd:minExclusive>
                            </rdf:Description>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#BiggerThan500um -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#BiggerThan500um">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#ParticleSize"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="&xsd;float"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minExclusive rdf:datatype="&xsd;float">500.0</xsd:minExclusive>
                            </rdf:Description>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#CSM_ON -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CSM_ON">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Status"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="&xsd;float">0.0</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="&xsd;float">100.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#CS_1000 -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CS_1000">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#ContaminationSensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasLocalLocation"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Pump_To_Oil_Filter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#SolidParticleContamination"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CSM_ON"/>
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CS_Drive"/>
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CS_Flow"/>
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#ISO_14"/>
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#ISO_4"/>
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#ISO_6"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#CS_Drive -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CS_Drive">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Drive"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="&xsd;float">0.0</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="&xsd;float">100.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#CS_Flow -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#CS_Flow">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#FlowRate"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="&xsd;float">0.0</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="&xsd;float">500.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Celsius -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Celsius">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#UnitOfMeasurement"/>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Connection -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Connection">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isConnectedTo"/>
                <owl:onClass rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Sub_System"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasConnectionFrom"/>
                <owl:onClass rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Sub_System"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Contamination -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Contamination">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasUnitOfMeasurement"/>
                <owl:allValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#UnitOfMeasurement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuredParticleSize"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#ParticleSize"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#ContaminationSensor -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#ContaminationSensor">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Hydac_Sensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasSurvivalProperty"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#SurvivalTemperatureRange"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                                <owl:someValuesFrom>
                                    <rdfs:Datatype>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdfs:Datatype>
                                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:minExclusive rdf:datatype="&xsd;float">-40.0</xsd:minExclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                            <rdfs:Datatype>
                                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:maxExclusive rdf:datatype="&xsd;float">80.0</xsd:maxExclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                        </owl:intersectionOf>
                                    </rdfs:Datatype>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#CS_Drive"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#CSM_ON"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingProperty"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#OperatingTemperatureRange"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
