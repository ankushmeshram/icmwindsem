                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Wind_Turbine"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Oil_Pump_To_Oil_Filter -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Pump_To_Oil_Filter">
