        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isConnectedTo"/>
                <owl:onClass rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Thermo_Bypass_Valve"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasConnectionFrom"/>
                <owl:onClass rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Filter"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Oil_Pump -->

