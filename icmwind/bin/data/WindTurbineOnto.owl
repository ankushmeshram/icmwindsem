    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#P_In -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#P_In">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Pressure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="&xsd;float">0.0</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="&xsd;float">16.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#P_Out -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#P_Out">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Pressure"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isPropertyOf"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="&xsd;float">-1.0</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="&xsd;float">9.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


