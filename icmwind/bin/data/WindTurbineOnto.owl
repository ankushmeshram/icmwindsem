        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasConnectionFrom"/>
                <owl:onClass rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Pump"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isConnectedTo"/>
                <owl:onClass rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Filter"/>
                <owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#OperatingPressureRange -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#OperatingPressureRange">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#OperatingProperty"/>
        <owl:disjointWith rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#OperatingTemperatureRange"/>
    </owl:Class>
    


