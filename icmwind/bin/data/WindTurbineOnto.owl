    <!-- http://www.icmwind.com/WindTurbineOnto.owl#MetallicContaminationSensor -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#MetallicContaminationSensor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasFeatureOfInterest"/>
                        <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
                        <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#MCS_Temp"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#measuresProperty"/>
                        <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#MetallicParticleContamination"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Hydac_Sensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingProperty"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#OperatingPressureRange"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                                <owl:someValuesFrom>
                                    <rdfs:Datatype>
                                        <owl:onDatatype rdf:resource="&xsd;float"/>
                                        <owl:withRestrictions rdf:parseType="Collection">
                                            <rdf:Description>
                                                <xsd:maxInclusive rdf:datatype="&xsd;float">20.0</xsd:maxInclusive>
                                            </rdf:Description>
                                        </owl:withRestrictions>
                                    </rdfs:Datatype>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#isSensorOf"/>
                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Gearbox"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingProperty"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#OperatingTemperatureRange"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                                <owl:someValuesFrom>
                                    <rdfs:Datatype>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdfs:Datatype>
                                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:minExclusive rdf:datatype="&xsd;float">-40.0</xsd:minExclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                            <rdfs:Datatype>
                                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:maxExclusive rdf:datatype="&xsd;float">70.0</xsd:maxExclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                        </owl:intersectionOf>
                                    </rdfs:Datatype>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#MetallicParticleContamination -->

