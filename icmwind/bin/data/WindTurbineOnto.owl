    <!-- http://www.icmwind.com/WindTurbineOnto.owl#HLB_S -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#HLB_S">
        <rdfs:subClassOf rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#RelativeHumidity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
