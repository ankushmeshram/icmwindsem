                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:minExclusive rdf:datatype="&xsd;float">-30.0</xsd:minExclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                            <rdfs:Datatype>
                                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:maxExclusive rdf:datatype="&xsd;float">80.0</xsd:maxExclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                        </owl:intersectionOf>
                                    </rdfs:Datatype>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasOperatingProperty"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#OperatingPressureRange"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#hasValue"/>
