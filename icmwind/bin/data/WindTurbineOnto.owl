            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Sensing"/>
            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Sensor"/>
            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Sub_System"/>
            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#SurvivalRange"/>
            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#System"/>
            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Time"/>
            <rdf:Description rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#UnitOfMeasurement"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
