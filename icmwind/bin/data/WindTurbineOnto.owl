                <owl:someValuesFrom rdf:resource="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Filter_To_Thermo_Bypass_Valve"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.icmwind.com/WindTurbineOnto.owl#Oil_Filter_To_Thermo_Bypass_Valve -->

    <owl:Class rdf:about="http://www.icmwind.com/WindTurbineOnto.owl#Oil_Filter_To_Thermo_Bypass_Valve">
