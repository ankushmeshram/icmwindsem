                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="&xsd;float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="&xsd;float">30.0</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
