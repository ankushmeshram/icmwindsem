    <!-- http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#hasPhysicalLocation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#hasPhysicalLocation">
