    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#BiggerThan200um -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#BiggerThan200um">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#ParticleSize"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#hasValue"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                        <owl:withRestrictions rdf:parseType="Collection">
                            <rdf:Description>
                                <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">200.0</xsd:minExclusive>
                            </rdf:Description>
                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#BiggerThan300um -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#BiggerThan300um">
