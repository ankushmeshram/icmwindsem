                                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#isPropertyOf"/>
                                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#ContaminationSensor"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


