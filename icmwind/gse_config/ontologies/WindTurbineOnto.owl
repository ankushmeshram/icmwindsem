    <!-- http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#ContaminationSensor -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#ContaminationSensor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#Hydac_Sensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#observesProperty"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#FlowRate"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#isPropertyOf"/>
                                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#Oil"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#hasFeatureOfInterest"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#Oil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/2012/4/WindTurbineOnto.owl#observesProperty"/>
                <owl:someValuesFrom>
